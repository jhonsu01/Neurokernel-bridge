# ===== LinuxIAKernel Configuration =====

# Required: Anthropic API key for Tier 3 decisions
ANTHROPIC_API_KEY=sk-ant-...

# Sensor configuration
LIAK_SENSOR_PATH=./execution/sensor.c
LIAK_SELF_FILTER_COMMS=python3,orchestrator

# Decision engine
LIAK_SIMILARITY_THRESHOLD=0.85
LIAK_MAX_API_CALLS_PER_MINUTE=20
LIAK_API_TIMEOUT_SECONDS=2.0
LIAK_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Batching
LIAK_BATCH_WINDOW_SECONDS=1.0
LIAK_MAX_BATCH_SIZE=50

# Memory
LIAK_CLAUDE_MEM_API_URL=http://localhost:37777
LIAK_ENABLE_CLAUDE_MEM=true
LIAK_SESSION_COMPRESS_INTERVAL_MINUTES=30

# Logging
LIAK_LOG_LEVEL=INFO
LIAK_LOG_FILE=./logs/orchestrator.jsonl

# ChromaDB
LIAK_CHROMADB_PATH=./system_memory

# Telegram (optional — alerts + remote commands)
# Create bot with @BotFather, get token
# Send message to bot, get chat_id from https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
